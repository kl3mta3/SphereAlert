<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>SphereAlert</RootNamespace>
    <AssemblyName>SphereAlert</AssemblyName>
    <Authors>Kenneth Lasyone</Authors>
    <Company>Sphere Labs</Company>
    <Version>1.0.0</Version>
    <Description>SphereAlert pushes site-wide alert banners to websites by updating a single DNS TXT record. Self-hosted, operator-owned, privacy-first. Sibling product to SphereSSL.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="8.0.10" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="AWSSDK.Route53" Version="3.7.*" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="sphere-alert.js">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
