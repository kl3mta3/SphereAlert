@page
@model SphereAlert.Pages.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="login-box">
    <div class="brand-lg">@(Model.Forced ? "Account Setup" : "Account Settings")</div>
    <div class="tagline">
        @(Model.Forced
            ? "Set your username and password before continuing."
            : "Update your username and password.")
    </div>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="notice notice-error">@Model.Error</div>
    }

    <form method="post">
        <div class="form-row">
            <label for="NewUsername">Username</label>
            <input type="text" id="NewUsername" asp-for="NewUsername" class="form-control"
                   autocomplete="username" required />
            <div class="form-hint">3–32 characters: letters, numbers, and . _ -</div>
        </div>
        <div class="form-row">
            <label for="CurrentPassword">Current password</label>
            <div class="pw-wrap">
                <input type="password" id="CurrentPassword" asp-for="CurrentPassword" class="form-control" autocomplete="current-password" required />
                <button type="button" class="pw-toggle" data-target="CurrentPassword" tabindex="-1" aria-label="Show password"><i class="bi bi-eye"></i></button>
            </div>
        </div>
        <div class="form-row">
            <label for="NewPassword">New password</label>
            <div class="pw-wrap">
                <input type="password" id="NewPassword" asp-for="NewPassword" class="form-control" autocomplete="new-password" required />
                <button type="button" class="pw-toggle" data-target="NewPassword" tabindex="-1" aria-label="Show password"><i class="bi bi-eye"></i></button>
            </div>
            <div class="form-hint">8–64 characters, with an uppercase letter, a lowercase letter, and a number.</div>
        </div>
        <div class="form-row">
            <label for="ConfirmPassword">Confirm new password</label>
            <div class="pw-wrap">
                <input type="password" id="ConfirmPassword" asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" required />
                <button type="button" class="pw-toggle" data-target="ConfirmPassword" tabindex="-1" aria-label="Show password"><i class="bi bi-eye"></i></button>
            </div>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">
            @(Model.Forced ? "Save & Continue" : "Save Changes")
        </button>
    </form>

    @if (!Model.Forced)
    {
        <p class="muted text-small" style="margin-top:16px;"><a href="/Settings">Back to settings</a></p>
    }
</div>

@section Scripts {
<script>
    document.querySelectorAll('.pw-toggle').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var input = document.getElementById(btn.dataset.target);
            var icon = btn.querySelector('i');
            if (!input) return;
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        });
    });
</script>
}
