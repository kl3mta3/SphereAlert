@page
@model SphereAlert.Pages.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="login-box">
    <div class="brand-lg">Change Password</div>
    <div class="tagline">
        @(Model.Forced
            ? "Set a new password before continuing."
            : "Update your account password.")
    </div>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="notice notice-error">@Model.Error</div>
    }

    <form method="post">
        <div class="form-row">
            <label for="CurrentPassword">Current password</label>
            <input type="password" id="CurrentPassword" asp-for="CurrentPassword" class="form-control" autocomplete="current-password" required />
        </div>
        <div class="form-row">
            <label for="NewPassword">New password</label>
            <input type="password" id="NewPassword" asp-for="NewPassword" class="form-control" autocomplete="new-password" required />
            <div class="form-hint">8–64 characters, with an uppercase letter, a lowercase letter, and a number.</div>
        </div>
        <div class="form-row">
            <label for="ConfirmPassword">Confirm new password</label>
            <input type="password" id="ConfirmPassword" asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" required />
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">Change Password</button>
    </form>

    @if (!Model.Forced)
    {
        <p class="muted text-small" style="margin-top:16px;"><a href="/Settings">Back to settings</a></p>
    }
</div>
