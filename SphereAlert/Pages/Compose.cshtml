@page
@model SphereAlert.Pages.ComposeModel
@using SphereAlert.Pages
@using SphereAlert.Models.AlertModels
@{
    ViewData["Title"] = "New Alert";
    var domainsToShow = Model.SelectedDomainIds.Count > 0
        ? Model.SelectedDomainIds
        : new List<string> { string.Empty };
}

<div class="page-head">
    <h1>New Alert</h1>
    <p>Pick a domain to load its live slots, then set and send any of the three alert slots.</p>
</div>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="notice notice-error">@Model.Error</div>
}

@if (Model.InstalledDomains.Count == 0)
{
    <div class="card">
        <div class="notice notice-info" style="margin:0;">
            No domains have a verified <code>sphere-alert.js</code> install yet. Open
            <a href="/Domains">Domains</a> and run <strong>Check script</strong> — only verified
            domains can receive an alert.
        </div>
    </div>
}
else
{
    <form method="post">
        <div class="card">
            <h2><i class="bi bi-globe2"></i> Domains</h2>
            <p class="muted text-small">
                The first domain loads its current alerts into the editors below. Add more with
                <strong>+</strong> — each Send goes to every domain listed.
            </p>
            <div id="domainRows">
                @for (int i = 0; i < domainsToShow.Count; i++)
                {
                    <div class="domain-row" style="display:flex; gap:8px; margin-bottom:8px;">
                        <select name="SelectedDomainIds" class="form-select domain-select" style="max-width:420px;">
                            <option value="">— select a domain —</option>
                            @foreach (var domain in Model.InstalledDomains)
                            {
                                <option value="@domain.DomainId" selected="@(domain.DomainId == domainsToShow[i])">
                                    @domain.Name
                                </option>
                            }
                        </select>
                        @if (i == 0)
                        {
                            <span class="badge-pill badge-unknown" style="align-self:center;">primary</span>
                        }
                        else
                        {
                            <button type="button" class="btn btn-sm btn-secondary" onclick="removeDomainRow(this)" title="Remove">&times;</button>
                        }
                    </div>
                }
            </div>
            <button type="button" class="btn btn-sm btn-ghost" onclick="addDomainRow()">
                <i class="bi bi-plus-lg"></i> Add domain
            </button>

            <template id="domainRowTemplate">
                <div class="domain-row" style="display:flex; gap:8px; margin-bottom:8px;">
                    <select name="SelectedDomainIds" class="form-select domain-select" style="max-width:420px;">
                        <option value="">— select a domain —</option>
                        @foreach (var domain in Model.InstalledDomains)
                        {
                            <option value="@domain.DomainId">@domain.Name</option>
                        }
                    </select>
                    <button type="button" class="btn btn-sm btn-secondary" onclick="removeDomainRow(this)" title="Remove">&times;</button>
                </div>
            </template>
        </div>

        @for (int i = 0; i < 3; i++)
        {
            int slot = i + 1;
            var input = Model.Slots.Count > i ? Model.Slots[i] : new SlotInput();
            <div class="card slot-editor" data-slot="@slot">
                <h2><i class="bi bi-card-text"></i><code>@(AlertLevels.SlotSubdomain(slot))</code></h2>

                <div style="display:flex; gap:16px; flex-wrap:wrap; align-items:center; margin-bottom:12px;">
                    <select asp-for="Slots[i].Level" class="form-select slot-level" style="max-width:150px;">
                        @foreach (var lvl in AlertLevels.All)
                        {
                            <option value="@lvl" selected="@(input.Level == lvl)">@PageHelpers.LevelLabel(lvl)</option>
                        }
                    </select>
                    <label class="form-hint" style="display:flex; align-items:center; gap:6px; margin:0;">
                        <input asp-for="Slots[i].Dismissable" class="slot-dismiss" /> Dismissable
                    </label>
                    <label class="form-hint" style="display:flex; align-items:center; gap:6px; margin:0;">
                        <input asp-for="Slots[i].ForceScroll" class="slot-scroll" /> Scroll
                    </label>
                    <span class="form-hint" style="display:flex; align-items:center; gap:6px; margin:0;">
                        Expires
                        <input type="datetime-local" class="form-control slot-expire-local" style="max-width:210px;" />
                    </span>
                    <input type="hidden" asp-for="Slots[i].ExpireUtc" class="slot-expire-utc" />
                </div>

                <textarea asp-for="Slots[i].Message" class="form-control slot-message" rows="2"
                          maxlength="@AlertLevels.MaxMessageLength"
                          placeholder="Alert message (leave blank to skip this slot)">@input.Message</textarea>
                <div class="form-hint"><span class="slot-charcount">0</span> / @AlertLevels.MaxMessageLength</div>

                <div class="form-row" style="margin-top:10px;">
                    <div class="banner-preview slot-preview lvl-info">
                        <span class="lvl-label slot-preview-label lvl-info">Info</span>
                        <div class="slot-preview-msg" style="flex:1;">(message)</div>
                    </div>
                    <div class="form-hint">TXT: <code class="txt-value slot-txt"></code></div>
                </div>

                <button type="submit" asp-page-handler="Send" name="slot" value="@slot" class="btn btn-primary">
                    <i class="bi bi-send"></i> Send slot @slot
                </button>
            </div>
        }
    </form>
}

@section Scripts {
<script>
    const LEVELS = [
        { cls: 'lvl-info',     label: 'Info',     border: '#185FA5' },
        { cls: 'lvl-low',      label: 'Notice',   border: '#3B6D11' },
        { cls: 'lvl-medium',   label: 'Warning',  border: '#854F0B' },
        { cls: 'lvl-high',     label: 'Alert',    border: '#993C1D' },
        { cls: 'lvl-critical', label: 'Critical', border: '#A32D2D' }
    ];
    const LEVEL_INDEX = { info: 0, low: 1, medium: 2, high: 3, critical: 4 };

    function addDomainRow() {
        const tpl = document.getElementById('domainRowTemplate');
        if (!tpl) return;
        document.getElementById('domainRows').appendChild(tpl.content.cloneNode(true));
    }
    function removeDomainRow(btn) { btn.closest('.domain-row').remove(); }

    function localFromUtc(iso) {
        const d = new Date(iso);
        if (isNaN(d.getTime())) return '';
        return new Date(d.getTime() - d.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
    }

    const domainRows = document.getElementById('domainRows');
    if (domainRows) {
        // Changing the first (primary) domain reloads with its live slot state.
        const primary = domainRows.querySelector('.domain-select');
        if (primary) primary.addEventListener('change', function () {
            window.location = this.value
                ? '/Compose?domainId=' + encodeURIComponent(this.value)
                : '/Compose';
        });

        document.querySelectorAll('.slot-editor').forEach(function (ed) {
            const level   = ed.querySelector('.slot-level');
            const msg     = ed.querySelector('.slot-message');
            const dismiss = ed.querySelector('.slot-dismiss');
            const scroll  = ed.querySelector('.slot-scroll');
            const expLoc  = ed.querySelector('.slot-expire-local');
            const expUtc  = ed.querySelector('.slot-expire-utc');
            const preview = ed.querySelector('.slot-preview');
            const pLabel  = ed.querySelector('.slot-preview-label');
            const pMsg    = ed.querySelector('.slot-preview-msg');
            const txt     = ed.querySelector('.slot-txt');
            const count   = ed.querySelector('.slot-charcount');

            function refresh() {
                const idx = LEVEL_INDEX[level.value] ?? 0;
                const lvl = LEVELS[idx];
                const m = msg.value.trim();
                const d = dismiss.checked ? 1 : 0;
                const s = scroll.checked ? 1 : 0;
                preview.className = 'banner-preview slot-preview ' + lvl.cls;
                preview.style.borderLeftColor = lvl.border;
                pLabel.className = 'lvl-label slot-preview-label ' + lvl.cls;
                pLabel.textContent = lvl.label;
                pMsg.textContent = m || '(message)';
                txt.textContent = JSON.stringify({ l: idx, m: m, d: d, s: s });
                count.textContent = msg.value.length;
            }
            function syncExpire() {
                expUtc.value = expLoc.value ? new Date(expLoc.value).toISOString() : '';
            }

            level.addEventListener('change', refresh);
            msg.addEventListener('input', refresh);
            dismiss.addEventListener('change', refresh);
            scroll.addEventListener('change', refresh);
            expLoc.addEventListener('input', syncExpire);
            expLoc.addEventListener('change', syncExpire);

            if (expUtc.value) expLoc.value = localFromUtc(expUtc.value);
            refresh();
        });

        const form = document.querySelector('form');
        if (form) form.addEventListener('submit', function () {
            document.querySelectorAll('.slot-editor').forEach(function (ed) {
                const el = ed.querySelector('.slot-expire-local');
                const eu = ed.querySelector('.slot-expire-utc');
                eu.value = el.value ? new Date(el.value).toISOString() : '';
            });
        });
    }
</script>
}
