@{
    var routePage = (ViewContext.RouteData.Values["page"] ?? "").ToString()!.ToLowerInvariant();
    var sessionData = Context.Session.GetString("UserSession");
    SphereAlert.Models.UserModels.UserSession? layoutUser = null;
    if (!string.IsNullOrEmpty(sessionData))
        layoutUser = Newtonsoft.Json.JsonConvert.DeserializeObject<SphereAlert.Models.UserModels.UserSession>(sessionData);
    bool chrome = layoutUser != null && !(layoutUser.MustChangePassword);
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · SphereAlert</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="main-container">
        <div class="top-bar">
		<div class="brand">
			<span>Sphere<strong>Alert</strong></span>
			<img src="~/img/spherealert_logo.png" asp-append-version="true" class="inline-logo" alt="SphereAlert logo" />
		</div>
            <div class="top-bar-icons">
                @if (chrome)
                {
					<a href="/Index?handler=Logout" class="icon-link power" title="Log out"><i class="bi bi-power"></i></a>
                    <a href="/Settings" class="icon-link" title="Settings"><i class="bi bi-gear-fill"></i></a>  
                }
            </div>
        </div>

        @if (chrome)
        {
            <nav class="sidebar-box">
                <a asp-page="/Dashboard" class="sidebar-link @(routePage == "/dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i><span class="sidebar-text">Dashboard</span>
                </a>
                <a asp-page="/Compose" class="sidebar-link @(routePage == "/compose" ? "active" : "")">
                    <i class="bi bi-megaphone"></i><span class="sidebar-text">New Alert</span>
                </a>
                <a asp-page="/ActiveAlerts" class="sidebar-link @(routePage == "/activealerts" ? "active" : "")">
                    <i class="bi bi-bell-fill"></i><span class="sidebar-text">Active</span>
                </a>
                <a asp-page="/History" class="sidebar-link @(routePage == "/history" ? "active" : "")">
                    <i class="bi bi-clock-history"></i><span class="sidebar-text">History</span>
                </a>
                <a asp-page="/Domains" class="sidebar-link @(routePage == "/domains" ? "active" : "")">
                    <i class="bi bi-globe2"></i><span class="sidebar-text">Domains</span>
                </a>
                <a asp-page="/Providers" class="sidebar-link @(routePage == "/providers" ? "active" : "")">
                    <i class="bi bi-hdd-network"></i><span class="sidebar-text">Providers</span>
                </a>
                <a asp-page="/Install" class="sidebar-link @(routePage == "/install" ? "active" : "")">
                    <i class="bi bi-file-earmark-zip"></i><span class="sidebar-text">Install</span>
                </a>
            </nav>
        }

        <main class="inner-box @(chrome ? "" : "full-bleed")">
            @if (chrome && TempData["Flash"] != null)
            {
                <div class="notice notice-success">@TempData["Flash"]</div>
            }
            @if (chrome && TempData["FlashError"] != null)
            {
                <div class="notice notice-error">@TempData["FlashError"]</div>
            }
            @RenderBody()
        </main>
    </div>

		<footer class="site-footer">
			<div class="footer-text">
			<span class="brand"> 
			<span>Sphere<strong>Alert</strong></span><img src="~/img/spherealert_logo.png" asp-append-version="true" class="inline-logo" alt="SphereAlert logo" /></span>
			<span class="copyright">&copy;2026 &ndash; Powered by SphereAlert</span>
			</div>
		</footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
