@page
@model SphereAlert.Pages.DomainsModel
@using SphereAlert.Pages
@{
    ViewData["Title"] = "Domains";
    bool editing = Model.EditTarget != null;
}

<div class="page-head">
    <h1>Domains</h1>
    <p>The zones SphereAlert can push banners to. Each alert writes a TXT record at <code>alert.&lt;domain&gt;</code>.</p>
</div>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="notice notice-error">@Model.Error</div>
}

<div class="card">
    <h2><i class="bi bi-cloud-download"></i> Import from Providers</h2>
    @if (Model.Providers.Count == 0)
    {
        <p class="muted">Add a <a href="/Providers">DNS provider</a> first, then refresh its domains here.</p>
    }
    else
    {
        <table class="data-table">
            <tbody>
            @foreach (var provider in Model.Providers)
            {
                <tr>
                    <td><strong>@provider.DisplayName</strong> <span class="muted">· @provider.Type</span></td>
                    <td style="text-align:right;">
                        <form method="post" asp-page-handler="Refresh" style="display:inline;">
                            <input type="hidden" name="providerId" value="@provider.ProviderId" />
                            <button type="submit" class="btn btn-sm btn-ghost"><i class="bi bi-arrow-repeat"></i> Refresh domains</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>

<div class="card">
    <h2><i class="bi bi-@(editing ? "pencil" : "plus-circle")"></i> @(editing ? "Edit Domain" : "Add a Domain Manually")</h2>
    <form method="post" asp-page-handler="@(editing ? "Edit" : "Add")">
        <input type="hidden" asp-for="InputDomainId" />
        <div class="form-row">
            <label for="InputName">Domain (zone)</label>
            <input type="text" id="InputName" asp-for="InputName" class="form-control"
                   style="max-width:340px;" placeholder="example.com" required />
        </div>
        <div class="form-row">
            <label for="InputProviderId">DNS provider</label>
            <select id="InputProviderId" asp-for="InputProviderId" class="form-select" style="max-width:340px;" required>
                <option value="">— select a provider —</option>
                @foreach (var provider in Model.Providers)
                {
                    <option value="@provider.ProviderId" selected="@(Model.InputProviderId == provider.ProviderId)">
                        @provider.DisplayName (@provider.Type)
                    </option>
                }
            </select>
        </div>
        <div class="btn-row">
            <button type="submit" class="btn btn-primary" disabled="@(Model.Providers.Count == 0)">
                @(editing ? "Save Changes" : "Add Domain")
            </button>
            @if (editing)
            {
                <a href="/Domains" class="btn btn-secondary">Cancel</a>
            }
        </div>
    </form>
</div>

<div class="card">
    <h2><i class="bi bi-globe2"></i> All Domains (@Model.TotalDomains)</h2>

    @if (Model.TotalDomains == 0)
    {
        <p class="muted">No domains yet. Import them from a provider or add one manually.</p>
    }
    else
    {
        <form method="post">
            <div class="toolbar">
                <button type="submit" asp-page-handler="CheckSelected" class="btn btn-sm btn-ghost">
                    <i class="bi bi-search"></i> Check selected
                </button>
                <button type="submit" asp-page-handler="DeleteSelected" class="btn btn-sm btn-danger"
                        onclick="return confirmBulkDelete()">
                    <i class="bi bi-trash"></i> Delete selected
                </button>
                <span class="muted text-small"><span id="selCount">0</span> selected</span>
            </div>

            <div style="overflow-x:auto;">
            <table class="data-table" id="domainTable">
                <thead>
                    <tr>
                        <th style="width:34px;"><input type="checkbox" id="selectAll" title="Select all on this page" /></th>
                        <th>Domain</th>
                        <th>Provider</th>
                        <th>Status</th>
                        <th>Script</th>
                        <th>Active alert</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var domain in Model.PageDomains)
                {
                    <tr>
                        <td><input type="checkbox" name="selectedDomainIds" value="@domain.DomainId" class="row-check" /></td>
                        <td><a href="/Domain?domainId=@domain.DomainId"><strong>@domain.Name</strong></a></td>
                        <td>@domain.ProviderDisplayName</td>
                        <td><span class="badge-pill @PageHelpers.StatusBadge(domain.Status)">@domain.Status</span></td>
                        <td><span class="badge-pill @PageHelpers.StatusBadge(domain.ScriptStatus)">@domain.ScriptStatus</span></td>
                        <td>
                            @if (!string.IsNullOrEmpty(domain.ActiveAlertLevel))
                            {
                                <span class="badge-pill @PageHelpers.LevelClass(domain.ActiveAlertLevel)">@PageHelpers.LevelLabel(domain.ActiveAlertLevel)</span>
                            }
                            else
                            {
                                <span class="muted">none</span>
                            }
                        </td>
                        <td>
                            <div style="display:flex; gap:6px;">
                                <button type="submit" asp-page-handler="Detect" name="domainId" value="@domain.DomainId"
                                        class="btn btn-sm btn-ghost" title="Check whether sphere-alert.js is installed">
                                    <i class="bi bi-search"></i>
                                </button>
                                <a href="/Domains?edit=@domain.DomainId" class="btn btn-sm btn-ghost" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="submit" asp-page-handler="Delete" name="domainId" value="@domain.DomainId"
                                        class="btn btn-sm btn-danger" title="Delete"
                                        onclick="return confirm('Remove @domain.Name from SphereAlert?');">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            </div>
        </form>

        @if (Model.TotalPages > 1)
        {
            <div class="toolbar" style="margin-top:14px; justify-content:center;">
                @if (Model.PageNumber > 1)
                {
                    <a href="/Domains?pageNumber=@(Model.PageNumber - 1)" class="btn btn-sm btn-secondary">
                        <i class="bi bi-chevron-left"></i> Previous
                    </a>
                }
                else
                {
                    <span class="btn btn-sm btn-secondary" style="opacity:.4;"><i class="bi bi-chevron-left"></i> Previous</span>
                }
                <span class="muted text-small">Page @Model.PageNumber of @Model.TotalPages</span>
                @if (Model.PageNumber < Model.TotalPages)
                {
                    <a href="/Domains?pageNumber=@(Model.PageNumber + 1)" class="btn btn-sm btn-secondary">
                        Next <i class="bi bi-chevron-right"></i>
                    </a>
                }
                else
                {
                    <span class="btn btn-sm btn-secondary" style="opacity:.4;">Next <i class="bi bi-chevron-right"></i></span>
                }
            </div>
        }
    }
</div>

@section Scripts {
<script>
    const selectAll = document.getElementById('selectAll');
    const rowChecks = Array.from(document.querySelectorAll('.row-check'));
    const selCount = document.getElementById('selCount');

    function updateCount() {
        const n = document.querySelectorAll('.row-check:checked').length;
        if (selCount) selCount.textContent = n;
        if (selectAll) selectAll.checked = n > 0 && n === rowChecks.length;
    }
    if (selectAll) {
        selectAll.addEventListener('change', function () {
            rowChecks.forEach(c => c.checked = selectAll.checked);
            updateCount();
        });
    }
    rowChecks.forEach(c => c.addEventListener('change', updateCount));
    updateCount();

    function confirmBulkDelete() {
        const n = document.querySelectorAll('.row-check:checked').length;
        if (n === 0) {
            alert('Select at least one domain first.');
            return false;
        }
        return confirm('Delete ' + n + ' selected domain(s)? This cannot be undone.');
    }
</script>
}
